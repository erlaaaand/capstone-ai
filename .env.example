# ============================================================
# Durian ML Service - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# ============================================================

# --- Application ---
APP_NAME=Durian Classification API
APP_VERSION=1.0.0
DEBUG=False

# --- Logging ---
LOG_LEVEL=INFO

# --- Model Configuration ---
MODEL_PATH=models/durian_classifier.onnx
CLASS_NAMES=Musang_King,Duri_Hitam,Sultan,Golden_Phoenix

# --- Image Processing ---
IMAGE_SIZE=224

# --- File Upload Constraints ---
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
MAX_FILE_SIZE_MB=10
