# ============================================================
# Durian ML Service - Environment Configuration
# ============================================================
# Copy file ini ke .env dan sesuaikan nilai untuk environment Anda.
# File .env TIDAK boleh di-commit ke git (sudah ada di .gitignore).
# ============================================================

# --- Application ---
APP_NAME=Durian Classification API
APP_VERSION=1.0.0
DEBUG=False

# --- Security ---
# Ganti dengan secret key yang kuat di production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_super_secret_api_key_here

# --- Logging ---
LOG_LEVEL=INFO

# --- Model Configuration ---
# Path ke file ONNX model (relatif dari root project)
MODEL_PATH=models/weights/efficientnet_b0.onnx

# 8 kelas durian sesuai training dan data/class_indices.json
# Urutan WAJIB sama dengan urutan folder saat training (alphabetical):
# D101=0, D13=1, D197=2, D198=3, D2=4, D200=5, D24=6, D88=7
CLASS_NAMES=D101,D13,D197,D198,D2,D200,D24,D88

# --- Image Processing ---
IMAGE_SIZE=224

# --- File Upload Constraints ---
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
MAX_FILE_SIZE_MB=10