# ==============================================================================
#  Durian Classification API — Enterprise Environment Configuration
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Durian Classification API
APP_VERSION=1.0.0
DEBUG=False          # True hanya untuk development (aktifkan /docs, /redoc)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_PATH=models/weights/your_model.h5/onnx
# Urutan WAJIB alphabetical (sesuai folder training):
CLASS_NAMES=D101,D13,D197,D2,D200,D24

# ── Image Processing ──────────────────────────────────────────────────────────
IMAGE_SIZE=224
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
MAX_FILE_SIZE_MB=10

# ── Enhancement Pipeline ──────────────────────────────────────────────────────
ENABLE_ENHANCEMENT=True     # Master switch enhancement
ENABLE_WHITE_BALANCE=True   # Auto white balance
ENABLE_CLAHE=True           # Contrast adaptive histogram equalization
ENABLE_SHARPENING=True      # Unsharp masking
CLAHE_CLIP_LIMIT=2.0        # Kekuatan CLAHE (1.0–4.0)

# ==============================================================================
#  ENTERPRISE SECURITY CONFIGURATION
# ==============================================================================

# ── API Keys ──────────────────────────────────────────────────────────────────
# Format: dk_live_<random32> untuk production, dk_test_<random32> untuk testing
# Generate key: python -c "import secrets; print('dk_live_' + secrets.token_urlsafe(24))"
#
# Key #1 — Frontend / Mobile App
API_KEY_1=dk_live
API_KEY_1_NAME=Frontend App
API_KEY_1_SCOPES=predict,health
API_KEY_1_TIER=standard
# API_KEY_1_EXPIRES_AT=1767225600   # Unix timestamp (opsional)
# API_KEY_1_DEPRECATED=false        # Set true saat rotasi key

# Key #2 — Internal Service / Backend
API_KEY_2=dk_live
API_KEY_2_NAME=Internal Backend Service
API_KEY_2_SCOPES=predict,health,admin
API_KEY_2_TIER=premium

# Key #3 — Testing / CI-CD (gunakan dk_test_ prefix)
API_KEY_3=dk_live
API_KEY_3_NAME=CI-CD Pipeline
API_KEY_3_SCOPES=predict,health
API_KEY_3_TIER=free

# Scopes yang tersedia: predict | health | admin | readonly
# Tier yang tersedia:   free(60/min) | standard(300/min) | premium(1000/min) | unlimited

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins yang diizinkan
# JANGAN gunakan "*" di production!
CORS_ORIGINS_STR=https://app.contoh.com,https://admin.contoh.com
# Development: CORS_ORIGINS_STR=http://localhost:3000,http://localhost:8080

# ── Trusted Hosts ─────────────────────────────────────────────────────────────
# Comma-separated hosts yang dipercaya (anti host-header injection)
ALLOWED_HOSTS_STR=api.contoh.com,*.contoh.com
# Development: ALLOWED_HOSTS_STR=*

# ==============================================================================
#  CARA GENERATE API KEY BARU:
#
#  python -c "
#  import secrets
#  live = 'dk_live_' + secrets.token_urlsafe(24)
#  test = 'dk_test_' + secrets.token_urlsafe(24)
#  print('LIVE:', live)
#  print('TEST:', test)
#  "
#
#  CARA ROTASI KEY (zero-downtime):
#  1. Generate key baru
#  2. Tambahkan sebagai API_KEY_4 di .env
#  3. Set API_KEY_1_DEPRECATED=true (key lama masih bisa dipakai, ada warning)
#  4. Setelah semua client update, hapus API_KEY_1 dari .env
# ==============================================================================
