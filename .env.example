# ==============================================================================
#  Durian Classification API — Enterprise Environment Configuration
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Durian Classification API
APP_VERSION=1.0.0
DEBUG=False          # True hanya untuk development (aktifkan /docs, /redoc)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_PATH=models/weights/efficientnet_b0.onnx

# PENTING: urutan WAJIB alphabetical sesuai folder training.
# BUG FIX: D101 dihapus — tidak ada dalam data/class_indices.json (hanya 5 kelas).
# Mismatch jumlah kelas akan menyebabkan ModelLoadException saat startup.
CLASS_NAMES=D13,D197,D2,D200,D24

# ── Image Processing ──────────────────────────────────────────────────────────
IMAGE_SIZE=224
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
MAX_FILE_SIZE_MB=10

# ── Enhancement Pipeline ──────────────────────────────────────────────────────
ENABLE_ENHANCEMENT=True
ENABLE_WHITE_BALANCE=True
ENABLE_CLAHE=True
ENABLE_SHARPENING=True
CLAHE_CLIP_LIMIT=2.0

# ==============================================================================
#  ENTERPRISE SECURITY CONFIGURATION
# ==============================================================================

# ── API Keys ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print('dk_live_' + secrets.token_urlsafe(24))"

# Key #1 — Frontend / Mobile App
API_KEY_1=dk_live_REPLACE_ME
API_KEY_1_NAME=Frontend App
API_KEY_1_SCOPES=predict,health
API_KEY_1_TIER=standard

# Key #2 — Internal Service / Backend
API_KEY_2=dk_live_REPLACE_ME
API_KEY_2_NAME=Internal Backend Service
API_KEY_2_SCOPES=predict,health,admin
API_KEY_2_TIER=premium

# Key #3 — Testing / CI-CD
API_KEY_3=dk_test_REPLACE_ME
API_KEY_3_NAME=CI-CD Pipeline
API_KEY_3_SCOPES=predict,health
API_KEY_3_TIER=free

# Scopes: predict | health | admin | readonly
# Tiers:  free(60/min) | standard(300/min) | premium(1000/min) | unlimited

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS_STR=https://app.contoh.com,https://admin.contoh.com
# Development: CORS_ORIGINS_STR=http://localhost:3000,http://localhost:8080

# ── Trusted Hosts ─────────────────────────────────────────────────────────────
ALLOWED_HOSTS_STR=api.contoh.com,*.contoh.com
# Development: ALLOWED_HOSTS_STR=*

# ==============================================================================
#  MARKET INTELLIGENCE AGENT
# ==============================================================================

# ── Ollama (Local LLM) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── NestJS Backend ────────────────────────────────────────────────────────────
NESTJS_BASE_URL=http://localhost:3000
NESTJS_INTERNAL_API_KEY=your_internal_secret_here

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Default: 02:30 WIB = 19:30 UTC (hari sebelumnya)
MI_AGENT_CRON_HOUR=19
MI_AGENT_CRON_MINUTE=30
MI_AGENT_DISABLED=false          # Set true untuk menonaktifkan agent
MI_AGENT_MAX_DURATION_SEC=3600   # Paksa stop setelah 1 jam

# ── Circuit Breaker ───────────────────────────────────────────────────────────
MI_CIRCUIT_BREAKER_THRESHOLD=3
MI_CIRCUIT_BREAKER_COOLDOWN_SEC=86400   # 24 jam
