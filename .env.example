# ==============================================================================
#  Durian Classification API — Enterprise Environment Configuration
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Durian Classification API
APP_VERSION=1.0.0
DEBUG=False          # True hanya untuk development (aktifkan /docs, /redoc)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Model ─────────────────────────────────────────────────────────────────────
# Diperbarui ke model hasil training v10 (EfficientNetV2-S)
MODEL_PATH=models/weights/durian_v10.onnx

# Urutan WAJIB alphabetical (sesuai folder training):
CLASS_NAMES=D13,D197,D2,D200,D24

# ── Image Processing ──────────────────────────────────────────────────────────
# Wajib 480 agar sesuai dengan input tensor model v10
IMAGE_SIZE=480
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
MAX_FILE_SIZE_MB=10

# ── Enhancement Pipeline ──────────────────────────────────────────────────────
ENABLE_ENHANCEMENT=True     # Master switch enhancement
ENABLE_WHITE_BALANCE=True   # Auto white balance
ENABLE_CLAHE=True           # Contrast adaptive histogram equalization
ENABLE_SHARPENING=True      # Unsharp masking
CLAHE_CLIP_LIMIT=2.0        # Kekuatan CLAHE (1.0–4.0)

# ==============================================================================
#  ENTERPRISE SECURITY CONFIGURATION
# ==============================================================================

# ── API Keys ──────────────────────────────────────────────────────────────────
# Key #1 — Frontend / Mobile App
API_KEY_1=your-api-key-for-testing-purposes-only
API_KEY_1_NAME=Frontend App
API_KEY_1_SCOPES=predict,health
API_KEY_1_TIER=standard

# Key #2 — Internal Service / Backend
API_KEY_2=your-api-key-for-testing-purposes-only
API_KEY_2_NAME=Internal Backend Service
API_KEY_2_SCOPES=predict,health,admin
API_KEY_2_TIER=premium

# Key #3 — Testing / CI-CD (gunakan dk_test_ prefix)
API_KEY_3=your-api-key-for-testing-purposes-only
API_KEY_3_NAME=CI-CD Pipeline
API_KEY_3_SCOPES=predict,health
API_KEY_3_TIER=free

# Scopes yang tersedia: predict | health | admin | readonly
# Tier yang tersedia:   free(60/min) | standard(300/min) | premium(1000/min) | unlimited

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins yang diizinkan
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:8080

# ── Trusted Hosts ─────────────────────────────────────────────────────────────
# Comma-separated hosts yang dipercaya (anti host-header injection)
ALLOWED_HOSTS_STR=*

# ==============================================================================
#  MARKET INTELLIGENCE AGENT
# ==============================================================================

# ── Ollama (Local LLM) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── NestJS Backend ────────────────────────────────────────────────────────────
NESTJS_BASE_URL=http://localhost:3000
NESTJS_INTERNAL_API_KEY=your_internal_secret_here

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Default: 02:30 WIB = 19:30 UTC (hari sebelumnya)
MI_AGENT_CRON_HOUR=19
MI_AGENT_CRON_MINUTE=30
MI_AGENT_DISABLED=false          # Set true untuk menonaktifkan agent
MI_AGENT_MAX_DURATION_SEC=3600   # Paksa stop setelah 1 jam

# ── Circuit Breaker ───────────────────────────────────────────────────────────
MI_CIRCUIT_BREAKER_THRESHOLD=3
MI_CIRCUIT_BREAKER_COOLDOWN_SEC=86400   # 24 jam